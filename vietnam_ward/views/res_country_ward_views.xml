<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="country_ward_list_view" model="ir.ui.view">
        <field name="model">res.country.ward</field>
        <field name="arch" type="xml">
            <list editable="bottom">
                <field name="name"/>
                <field name="code"/>
                <field name="state_id"/>
            </list>
        </field>
    </record>

    <record id="action_country_ward" model="ir.actions.act_window">
        <field name="name">Wards</field>
        <field name="res_model">res.country.ward</field>
        <field name="view_mode">list</field>
    </record>

    <!-- Menu -->

    <record id="contacts.menu_country_group" model="ir.ui.menu">
        <field name="sequence" eval="200"/>
    </record>

    <menuitem id="menu_country_ward"
        action="action_country_ward"
        name="Wards"
        parent="contacts.menu_localisation"
        sequence="150"/>

</odoo>